{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ridex",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": false
  },
  "build": {
    "command": "pnpm run build"
  },
  "assets": {
    "directory": ".next/static",
    "binding": "ASSETS"
  }
}